{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/kuu/ghq/github.com/kuu-lab/swifty-kotlin/.codex/hooks/swift-lint-pre-commit.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/kuu/ghq/github.com/kuu-lab/swifty-kotlin/.codex/hooks/swift-lint-post-edit.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
